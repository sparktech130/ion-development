# Ion Smart Platform — variables de entorno
# Copia este fichero a .env y rellena los valores reales.
# NUNCA subas .env al repositorio.

# ── Base de datos ─────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=cambia_esto
MYSQL_USER=ionsmart
MYSQL_PASSWORD=cambia_esto

# ── Nombres de las bases de datos ─────────────────────────────────────────────
CORE_DB_NAME=core
CITY_DB_NAME=city
INDUSTRY_DB_NAME=industry
SKI_DB_NAME=ski

# ── Modulos habilitados (separados por coma) ──────────────────────────────────
ENABLED_DBS=core,city

# ── Migraciones Goose ─────────────────────────────────────────────────────────
GOOSE_CMD=up

# ── Puertos (CASE los sobreescribe automaticamente) ───────────────────────────
# APP_PORT=8080
# MYSQL_PORT=3306
# PHPMYADMIN_PORT=8081
