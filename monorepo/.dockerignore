.env
.env.*

# Control de versiones
.git/
.gitignore
.gitmodules

# Docker — no tiene sentido incluirlos en la imagen
docker-compose*.yml
Dockerfile*
.dockerignore

# Documentación
*.md

# Artefactos de build del frontend (si los hubiera en monorepo)
node_modules/
dist/
