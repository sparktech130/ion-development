        "tracking": {
            "name": "AI tracking speed",
            "hint": "The AI tracking speed feature enables users to adjust the frame rate at which the AI processes data.\nModifying this from the default setting may impact server performance and reduce the number of AI streams that can run simultaneously on the same device.",
            "values": {
                "low": "5 FPS - Optimized for most of the security surveillance use cases",
                "medium": "10 FPS - Optimized for tracking fast moving targets (e.g. cyclists)",
                "high": "15 FPS - Optimized for capturing targets that move very fast (e.g. electric scooters)"
            }
        },
        "detection": {
            "name": "Detection mode",
            "hint": "The Detection Mode setting determines how detection is triggered:\n- Smart Detection: Relies on motion to trigger detections, making it efficient in scenarios where movement is the primary indicator of interest. Ideal for environments with sparse activity, minimizing processing overhead by focusing only on areas with motion.\n- Active Detection: Performs fullscreen detection regardless of motion, ensuring comprehensive analysis. This mode is especially useful in dense scenes where motion is widespread or for scenarios requiring detection of stationary objects, such as people or vehicles in counting.",
            "values": {
                "smart": "Smart detection",
                "active": "Active detection"
            }
        },
        "sensitivity": {
            "name": "Detection sensivity",
            "hint": "Increasing detection sensitivity improves the ability to detect challenging targets (e.g., smaller, occluded, or affected by lens noise) but may lead to more False Positives.\nChange 'Detection Sensitivity' settings to 'High' if the system misses events involving small objects or in busy scenes.",
            "values": {
                "low": "Low",
                "medium": "Medium",
                "high": "High"
            }
        },
        "movement": {
            "name": "Movement sensivity",
            "hint": "The movement sensitivity controls how the system determines whether motion is occurring.\nEnvironmental factors such as rain, snow, camera noise, and light reflections can cause false motion detections. Lowering motion sensitivity can minimize these false detections but increases the risk of missing fast-moving or short-duration objects.",
            "values": {
                "low": "Low",
                "medium": "Medium",
                "high": "High"
            }
        },
        "attributes_extraction": {
            "name": "Attributes extraction",
            "hint": "Attribute extraction enables the collection of various characteristics of vehicles and people — such as color, vehicle type, gender, age, whether they are carrying a bag, smoking, and more."
        }
    }
