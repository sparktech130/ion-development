        "tracking": {
            "name": "Velocitat de seguiment d'IA",
            "hint": "La funció de velocitat de seguiment d'IA permet ajustar la freqüència de fotogrames a la qual la IA processa les dades.\nModificar aquest valor respecte a l'ajust predeterminat pot afectar el rendiment del servidor i reduir el nombre de fluxos d'IA que poden executar-se simultàniament en el mateix dispositiu.",
            "values": {
                "low": "5 FPS - Optimitzat per a la majoria dels casos d'ús de vigilància de seguretat",
                "medium": "10 FPS - Optimitzat per al seguiment d'objectius de moviment ràpid (p. ex. ciclistes)",
                "high": "15 FPS - Optimitzat per capturar objectius que es mouen molt ràpid (p. ex. patinets elèctrics)"
            }
        },
        "detection": {
            "name": "Mode de detecció",
            "hint": "La configuració del mode de detecció determina com s'activa la detecció:\n- Detecció intel·ligent: es basa en el moviment per activar les deteccions, cosa que la fa eficient en escenaris on el moviment és el principal indicador d'interès. Ideal per a entorns amb poca activitat, minimitzant la càrrega de processament en centrar-se només en les àrees amb moviment.\n- Detecció activa: realitza detecció en pantalla completa independentment del moviment, garantint una anàlisi completa. Aquest mode és especialment útil en escenes denses o en escenaris que requereixen la detecció d'objectes estàtics, com persones o vehicles en recompte.",
            "values": {
                "smart": "Detecció intel·ligent",
                "active": "Detecció activa"
            }
        },
        "sensitivity": {
            "name": "Sensibilitat de detecció",
            "hint": "Augmentar la sensibilitat de detecció millora la capacitat de detectar objectius difícils (per exemple, més petits, parcialment ocults o afectats pel soroll de la lent), però pot generar més falsos positius.\nCanvia la configuració de 'Sensibilitat de detecció' a 'Alta' si el sistema omet esdeveniments que impliquen objectes petits o en escenes molt concorregudes.",
            "values": {
                "low": "Baixa",
                "medium": "Mitjana",
                "high": "Alta"
            }
